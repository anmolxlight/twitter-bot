{
  "version": 2,
  "crons": [
    {
      "path": "/api/cron/tweet",
      "schedule": "0 */3 * * *"
    },
    {
      "path": "/api/cron/health",
      "schedule": "*/30 * * * *"
    }
  ],
  "functions": {
    "src/main.py": {
      "runtime": "python3.9",
      "maxDuration": 300
    }
  },
  "env": {
    "PYTHONPATH": ".",
    "VERCEL_DEPLOYMENT": "true"
  }
}
